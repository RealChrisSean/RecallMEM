# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# RecallMEM additions
_reference/
*.db
*.sqlite
*.sqlite3
data/
dump.sql
backup.sql
**/exports/
**/personal-data/
.claude/

# Personal notes / agent context - never commit
DEVLOG.md
NOTES.md
PERSONAL.md
CLAUDE.md
AGENTS.md
chrisprofile.md
.cursor/
.aider*

# Synced npm publish artifacts (regenerated from bin/ via scripts/sync-publish.js)
publish/bin/
publish/LICENSE
publish/NOTICE
publish/README.md
publish/*.tgz
