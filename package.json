{
  "name": "recallmem",
  "version": "0.1.3",
  "description": "Private, local-first AI chatbot with persistent working memory",
  "license": "Apache-2.0",
  "author": "Chris Sean",
  "homepage": "https://github.com/RealChrisSean/RecallMEM",
  "repository": {
    "type": "git",
    "url": "https://github.com/RealChrisSean/RecallMEM.git"
  },
  "private": true,
  "bin": {
    "recallmem": "./bin/recallmem.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "migrate": "tsx scripts/migrate.ts",
    "cli": "node ./bin/recallmem.js",
    "publish:sync": "node scripts/sync-publish.js",
    "publish:pack": "npm run publish:sync && cd publish && npm pack",
    "publish:dry": "npm run publish:sync && cd publish && npm publish --dry-run",
    "publish:npm": "npm run publish:sync && cd publish && npm publish --access public",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@langchain/core": "^1.1.39",
    "@langchain/openai": "^1.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "langfuse": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "langfuse": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitest/ui": "^4.1.3",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.3"
  }
}
